# Normalise every text file to LF — in the repo and on checkout.
# This kills the "LF will be replaced by CRLF" churn that Git's global
# core.autocrlf=true causes on Windows, and keeps this web app byte-identical
# across machines and CI. .gitattributes wins over core.autocrlf.
* text=auto eol=lf

# Binary assets — Git must never touch line endings or try to diff these.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
